{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "gcc build active file",
            "type": "shell",
            "command": "D:\\Dev-Cpp\\MinGW64\\bin\\gcc.exe",
            "args": [
                "-std=c11",
                "-g",
                "${fileDirname}\\main.c",
                "${fileDirname}\\hash_table.c",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Compile all .c files in the active file's directory"
        }
    ]
}
